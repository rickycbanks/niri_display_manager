[Unit]
Description=Niri Display Manager Hotplug Daemon
Documentation=https://github.com/rickycbanks/niri_display_manager
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/niri-display-manager --daemon
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical-session.target
